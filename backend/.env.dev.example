# VortexFlow — local DEVELOPMENT env. Copy to backend/.env.dev (git-ignored).
# `make dev-backend` / `make dev-seed` create it from this file automatically.
#
# ⚠️ DEV ONLY. Every value here is a local placeholder — NEVER use in production.
# Production config is supplied via the deployment env / docker-compose, not this file.

# Required. Any string >= 32 chars. Stable so encrypted dev data (certs, SSO
# secrets) round-trips across restarts. Changing it invalidates existing
# encrypted rows in the dev DB.
VORTEXFLOW_SECRET_KEY=vortexflow-dev-secret-key-not-for-production

# Dev Postgres + Redis (local dev containers — see docker/.env).
VORTEXFLOW_DATABASE_URL=postgresql+asyncpg://vortexflow:vortexflow@localhost:5432/vortexflow
VORTEXFLOW_REDIS_URL=redis://localhost:6380/0
VORTEXFLOW_VM_URL=http://localhost:8428

# Public base URL of the dev API. Needed for SAML (SP entity id + ACS url derive
# from it) and the agent install one-liner.
VORTEXFLOW_PUBLIC_URL=http://localhost:8001

# Where rendered component TLS certs are written. A writable temp dir in dev so
# agent cert-delivery tests don't need root (prod default: /etc/vortexflow/component-certs).
VORTEXFLOW_COMPONENT_CERTS_DIR=/tmp/vfcerts

# Optional: path to a `vector` binary for the server-side validate gate. Left as
# the bare name; if not on PATH, validation degrades to "unavailable" (non-blocking).
VORTEXFLOW_VECTOR_BIN=vector
