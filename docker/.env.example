POSTGRES_PASSWORD=changeme_strong_password
VORTEXFLOW_SECRET_KEY=changeme_run_openssl_rand_hex_32
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=changeme_strong_password

# Optional: SSO
# VORTEXFLOW_AZURE_TENANT_ID=
# VORTEXFLOW_AZURE_CLIENT_ID=
# VORTEXFLOW_AZURE_CLIENT_SECRET=

# ── Metrics retention / disk (VictoriaMetrics) ───────────────────────────────
# Retention is the main disk lever (disk ≈ retention × series cardinality).
# VM_RETENTION_PERIOD=30d            # e.g. 90d, 1y
# VM_MIN_FREE_DISK_BYTES=1073741824  # refuse writes below this free space (1 GiB)

# ── DB retention (daily prune of unbounded operational tables) ───────────────
# 0 = keep forever. Audit logs are compliance-sensitive — set deliberately.
# AUDIT_RETENTION_DAYS=365
# EVENT_RETENTION_DAYS=90
# NOTIFICATION_RETENTION_DAYS=30
